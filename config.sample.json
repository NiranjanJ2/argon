{
  "agents": {
    "defaults": {
      "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
      "fallbackModel": "nvidia/llama-3.3-nemotron-super-49b-v1.5",
      "provider": "custom"
    }
  },
  "providers": {
    "custom": {
      "apiKey": "nvapi-YOUR_NIM_API_KEY",
      "apiBase": "https://integrate.api.nvidia.com/v1"
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allowFrom": ["YOUR_DISCORD_USER_ID"],
      "groupPolicy": "mention"
    },
    "whatsapp": {
      "enabled": true,
      "phoneNumber": "YOUR_PHONE_E164",
      "bridgePort": 3996,
      "allowFrom": ["YOUR_PHONE_E164"]
    }
  },
  "google": {
    "enabled": true
  },
  "tools": {
    "exec": { "enable": false },
    "web": {
      "enable": true,
      "search": { "provider": "duckduckgo" }
    }
  }
}
