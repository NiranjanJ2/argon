{
  "agents": {
    "defaults": {
      "model": "openai/gpt-oss-20b",
      "provider": "custom"
    }
  },
  "providers": {
    "custom": {
      "apiKey": "YOUR_GROQ_API_KEY",
      "apiBase": "https://api.groq.com/openai/v1"
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allowFrom": ["YOUR_DISCORD_USER_ID"],
      "groupPolicy": "mention"
    },
    "whatsapp": {
      "enabled": true,
      "phoneNumber": "YOUR_PHONE_NUMBER",
      "bridgePort": 3996,
      "allowFrom": ["YOUR_WHATSAPP_NUMBER"]
    }
  },
  "google": {
    "enabled": true
  },
  "tools": {
    "exec": { "enable": false },
    "web": {
      "enable": true,
      "search": { "provider": "duckduckgo" }
    }
  }
}
